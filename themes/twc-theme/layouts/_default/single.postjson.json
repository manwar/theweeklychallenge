{{- $content := .RawContent -}}
{{- $content = $content | replaceRE `<br\s*/?>` "\n" -}}
{{- $content = $content | replaceRE `<[^>]+>` "" -}}
{
  "slug":    {{ .File.BaseFileName | jsonify }},
  "title":   {{ .Title | jsonify }},
  "author":  {{ .Params.author | jsonify }},
  "date":    {{ .Date.Format "2 Jan 2006" | jsonify }},
  "image":   {{ with .Params.image }}{{ printf "https://theweeklychallenge.org/%s" . | jsonify }}{{ else }}""{{ end }},
  "content": {{ $content | jsonify }}
}
