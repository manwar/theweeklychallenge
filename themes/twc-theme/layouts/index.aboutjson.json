{{- $a := .Site.Params.about -}}
{
  "image":     {{ printf "https://theweeklychallenge.org/%s" $a.image | jsonify }},
  "github":    {{ $a.github    | jsonify }},
  "twitter":   {{ $a.twitter   | jsonify }},
  "linkedin":  {{ $a.linkedin  | jsonify }},
  "mastodon":  {{ $a.mastodon  | jsonify }},
  "website":   {{ $a.website   | jsonify }},
  "sections": [
    {
      "subtitle": {{ $a.subtitle1 | jsonify }},
      "content":  {{ $a.content1  | jsonify }}
    },
    {
      "subtitle": {{ $a.subtitle2 | jsonify }},
      "content":  {{ $a.content2  | jsonify }}
    },
    {
      "subtitle": {{ $a.subtitle3 | jsonify }},
      "content":  {{ $a.content3  | jsonify }}
    }
  ]
}
