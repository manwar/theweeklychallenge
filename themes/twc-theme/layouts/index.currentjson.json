{{- /* 1. Pull data directly from config.toml [params] */ -}}
{{- $currentWeekNum := .Site.Params.currentWeek -}}
{{- $banner         := .Site.Params.banner -}}

{{- /* 2. Find the page for this week to get the URL and Date */ -}}
{{- $paddedWeek   := printf "%03d" (int $currentWeekNum) -}}
{{- $expectedFile := printf "perl-weekly-challenge-%s" $paddedWeek -}}
{{- $challenges   := where .Site.RegularPages "Section" "blog" -}}
{{- $latest       := "" -}}
{{- range $challenges -}}
    {{- if eq .File.BaseFileName $expectedFile -}}{{- $latest = . -}}{{- end -}}
{{- end -}}

{{- if $latest -}}
    {{- /* 3. Output JSON using ONLY config values for titles and descriptions */ -}}
    {
      "week":        {{ $currentWeekNum }},
      "title":       {{ $latest.Title | jsonify }},
      "url":         {{ $latest.Permalink | jsonify }},
      "pubDate":     {{ $latest.Date.Format "2006-01-02" | jsonify }},
      "task1_title": {{ $banner.taskLabel1 | jsonify }},
      "task1_desc":  {{ $banner.taskDesc1  | jsonify }},
      "task1_body":  "",
      "task2_title": {{ $banner.taskLabel2 | jsonify }},
      "task2_desc":  {{ $banner.taskDesc2  | jsonify }},
      "task2_body":  ""
    }
{{- else -}}
    {{- /* Stop build to protect existing current.json if the file isn't found */ -}}
    {{- errorf "FATAL: Config says Week %v, but %s.md not found in content/blog/" $currentWeekNum $expectedFile -}}
{{- end -}}
