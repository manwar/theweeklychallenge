{{- $all := where .Site.RegularPages "Section" "blog" -}}
{{- $blogs := slice -}}
{{- range $all -}}
  {{- $t := .Params.title -}}
  {{- $isChallenge := strings.HasPrefix $t "The Weekly Challenge -" -}}
  {{- $isRecap     := strings.HasPrefix $t "RECAP" -}}
  {{- $isChampion  := strings.HasPrefix $t "Meet The Champion" -}}
  {{- $isGuest     := strings.HasPrefix $t "The Weekly Challenge - Guest" -}}
  {{- if not (or $isChallenge $isRecap $isChampion $isGuest) -}}
    {{- $blogs = $blogs | append . -}}
  {{- end -}}
{{- end -}}
{{- $blogs = sort $blogs "Date" "desc" -}}
[
{{- range $i, $p := $blogs }}{{ if $i }},{{ end }}
{
  "title": {{ $p.Title | jsonify }},
  "url":   {{ $p.Permalink | jsonify }},
  "date":  {{ $p.Date.Format "2 Jan 2006" | jsonify }},
  "image": {{ with $p.Params.image }}{{ printf "https://theweeklychallenge.org/%s" . | jsonify }}{{ else }}""{{ end }},
  "tags":  {{ with $p.Params.tags }}{{ jsonify . }}{{ else }}[]{{ end }}
}
{{- end }}
]
