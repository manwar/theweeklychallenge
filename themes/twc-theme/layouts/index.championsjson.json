{{- /* Use champions.yml as the source of truth for all champions */ -}}
{{- $members := hugo.Data.champions.members -}}
[
{{- range $i, $m := $members }}{{ if $i }},{{ end }}
{{- $url := "" -}}
{{- with $m.interview -}}
  {{- $url = printf "https://theweeklychallenge.org%s" . -}}
{{- end -}}
{{- $image := printf "https://theweeklychallenge.org/%s" $m.image -}}
{{- $month := $m.description | replaceRE ` - ` " " -}}
{
  "name":  {{ $m.name | jsonify }},
  "month": {{ $month | jsonify }},
  "url":   {{ $url | jsonify }},
  "image": {{ $image | jsonify }}
}
{{- end }}
]
